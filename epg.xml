function generateEPG(videos){

let epg=[]
let sec=0

while(sec<86400){

for(let v of videos){

epg.push({

title:v.title,
video:v.id,
start:sec,
duration:v.duration

})

sec+=v.duration

if(sec>=86400) break

}

}

return epg

}

function formatTime(sec){

let h=Math.floor(sec/3600)
let m=Math.floor((sec%3600)/60)

return h.toString().padStart(2,"0")+":"+m.toString().padStart(2,"0")

}